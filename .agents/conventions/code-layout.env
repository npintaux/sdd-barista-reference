# code-layout.env — machine-readable layout contract (twin of code-layout.md)
#
# Sourced by the SDD hooks (post-implement, pre-implement). Declares Barista's
# concrete layout so enforcement needs no project knowledge in the plugin. Keep in
# sync with code-layout.md. Regexes are POSIX ERE.

# A "code commit" is one touching src/.
CODE_PATH_REGEX='^src/'

# One-rule-per-file modules.
RULES_DIR='src/barista/core/rules'
RULE_FILE_PATTERN='^r[0-9]+_[a-z0-9_]+\.py$'
RULES_SKIP_FILES='__init__.py base.py'

# Tests mirror the rules: tests/test_<rule>.py
TESTS_DIR='tests'
TEST_FILE_PREFIX='test_'

# The pure core must stay I/O-free — it must not import the agent shell.
PURE_DIR='src/barista/core'
FORBIDDEN_IMPORT_REGEX='import +barista\.agent|from +barista\.agent|from +\.\.agent|from +\.agent'
